<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".activities.BrowseCampsActivity">

    <!-- Search Bar -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/search"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Filter Chips -->
    <com.google.android.material.chip.ChipGroup
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <com.google.android.material.chip.Chip
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/name" />

        <com.google.android.material.chip.Chip
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/start_date" />

        <com.google.android.material.chip.Chip
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/end_date" />

        <com.google.android.material.chip.Chip
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Szervező" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Image Gallery Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/camp_pictures"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"/>

    <!-- Horizontal Image Scroll View -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Images to add:
     2025. 04. 24.     16:38         702690 cserkesztabor.jpg
     2025. 04. 14.     22:06          19810 drcode.jpg
     2025. 04. 14.     22:05           5102 favicon_96.png
     2025. 04. 14.     22:06         953320 forest_summer_camp.jpg
     2025. 04. 14.     22:06         194629 group_of_children_lying_in_the_grass_in_a_circle.jpg
     2025. 04. 14.     22:05           5102 ic_notification.png
     2025. 04. 14.     22:06          75120 island_camp.jpg
     2025. 04. 14.     22:06         440843 nyari_tabor_jatek.jpg
     2025. 04. 14.     22:06          14612 szent_margit.jpg
     2025. 04. 08.     22:48          11348 szent_margit_cserkeszcsapat.jpg
     2025. 04. 14.     22:06          20439 szinjatszotabor.jpg
     2025. 04. 24.     16:37         418095 tabortuz_jatekok.jpg
     2025. 04. 14.     22:05         493635 zankai_elmenytabor.jpg
            -->
            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/circle"
                android:layout_marginEnd="8dp"
                android:scaleType="centerCrop"/>

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/circle"
                android:layout_marginEnd="8dp"
                android:scaleType="centerCrop"/>

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/circle"
                android:layout_marginEnd="8dp"
                android:scaleType="centerCrop"/>

            <!-- Add more images as needed from res/assets/images/ -->
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Camps List Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Elérhető táborok"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- RecyclerView for Camps -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="16dp"/>
</LinearLayout>